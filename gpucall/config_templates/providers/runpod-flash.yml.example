name: runpod-flash
adapter: runpod-flash
max_data_classification: confidential
gpu: A100-80G
vram_gb: 80
max_model_len: 8192
cost_per_second: 0.00083
modes: [sync, async]
endpoint: null
# Deprecated compatibility name.
# Prefer runpod-vllm-serverless.yml.example or runpod-vllm-flashboot.yml.example.
# target is the deployed RunPod Serverless endpoint ID for a real worker-vLLM endpoint.
target: ""
# Official RunPod worker-vLLM uses the OpenAI-compatible route:
# https://api.runpod.ai/v2/<endpoint_id>/openai/v1/chat/completions
# See https://github.com/runpod-workers/worker-vllm and
# https://docs.runpod.io/serverless/vllm/get-started.
image: runpod/worker-v1-vllm:v2.18.1
endpoint_contract: openai-chat-completions
input_contracts: [chat_messages]
output_contract: openai-chat-completions
stream_contract: none
# model: Qwen/Qwen3-8B
