# Disabled by default. Set true only on an operator-controlled inbox host.
# This only materializes reviewed recipe YAML and static catalog readiness.
# It never runs billable smoke tests or activates production routing.
recipe_inbox_auto_materialize: false
# Optional escalation chain. Keep all false unless this operator host is
# allowed to spend provider money and mutate production routing from inbox
# submissions.
recipe_inbox_auto_promote_candidates: false
recipe_inbox_auto_billable_validation: false
recipe_inbox_auto_activate_validated: false
recipe_inbox_promotion_work_dir:
# manual: administrators issue keys explicitly and hand them off through an
# operator-approved channel.
# handoff_file: tenant-onboard may generate a 0600 handoff file containing the
# caller gateway key and onboarding URLs.
# trusted_bootstrap: trusted clients may POST to /v2/bootstrap/tenant-key and
# receive a tenant-scoped key without human handoff.
api_key_handoff_mode: manual
api_key_bootstrap_allowed_cidrs: []
api_key_bootstrap_allowed_hosts: []
api_key_bootstrap_gateway_url:
api_key_bootstrap_recipe_inbox:
